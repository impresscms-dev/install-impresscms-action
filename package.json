{
  "name": "install-impresscms-action",
  "description": "GitHub action to install ImpressCMS",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --config jest.integration.config.js",
    "format": "npm run pack",
    "format-check": "node scripts/pack.js --format-check",
    "lint": "eslint --no-warn-ignored \"src/**/*.js\" \"scripts/**/*.js\"",
    "pack": "node scripts/pack.js"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "jest": "^30.4.2"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "node-dependency-injection": "^4.2.0",
    "playwright": "^1.59.1",
    "testcontainers": "^12.0.4"
  }
}
